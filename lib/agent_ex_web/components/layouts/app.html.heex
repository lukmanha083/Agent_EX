<div class="flex h-screen bg-gray-950">
  <!-- Mobile top bar -->
  <div class="fixed top-0 left-0 right-0 z-40 flex items-center gap-3 px-4 h-14 bg-gray-900 border-b border-gray-800 lg:hidden">
    <.sheet id="mobile-nav">
      <.sheet_trigger>
        <button type="button" class="p-2 -ml-2 rounded-md text-gray-400 hover:text-white hover:bg-gray-800 min-h-[44px] min-w-[44px] flex items-center justify-center" aria-label="Open navigation">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5">
            <path fill-rule="evenodd" d="M2 4.75A.75.75 0 0 1 2.75 4h14.5a.75.75 0 0 1 0 1.5H2.75A.75.75 0 0 1 2 4.75ZM2 10a.75.75 0 0 1 .75-.75h14.5a.75.75 0 0 1 0 1.5H2.75A.75.75 0 0 1 2 10Zm0 5.25a.75.75 0 0 1 .75-.75h14.5a.75.75 0 0 1 0 1.5H2.75a.75.75 0 0 1-.75-.75Z" clip-rule="evenodd" />
          </svg>
        </button>
      </.sheet_trigger>
      <.sheet_content side="left" class="w-64 p-0 bg-gray-900 border-r border-gray-800">
        <div class="flex flex-col h-full">
          <div class="flex items-center gap-2 h-14 px-4 border-b border-gray-800">
            <img src={~p"/images/logo-icon.svg"} alt="AgentEx" class="h-7 w-7" />
            <span class="font-semibold text-white text-sm">AgentEx</span>
          </div>
          <nav class="flex-1 px-3 py-4 space-y-1">
            <p class="px-2 mb-2 text-[11px] font-medium text-gray-500 uppercase tracking-wider">Platform</p>
            <.link navigate={~p"/chat"} class={[
              "flex items-center gap-3 px-2 py-2 text-sm rounded-md transition-colors",
              nav_active?(@socket, AgentExWeb.ChatLive) && "bg-gray-800 text-white font-medium" || "text-gray-400 hover:bg-gray-800/50 hover:text-gray-200"
            ]}>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 shrink-0">
                <path d="M3.505 2.365A41.369 41.369 0 0 1 9 2c1.863 0 3.697.124 5.495.365 1.247.167 2.18 1.108 2.435 2.268a4.45 4.45 0 0 0-.577-.069 43.36 43.36 0 0 0-4.353 0C9.168 4.749 7 6.733 7 9.035c0 1.358.635 2.565 1.625 3.346-.463.305-.96.559-1.484.756-1.077.405-1.916-.265-1.916-1.378V10.5c0-.235.007-.467.022-.696A4.998 4.998 0 0 1 2 5.869V5.75c0-1.505.923-2.97 2.17-3.29a.228.228 0 0 0-.165-.035ZM12 8.217a33.36 33.36 0 0 0-3.397.166c-1.04.152-1.853 1.03-1.853 2.163v1.01c0 1.133.813 2.01 1.853 2.163A33.36 33.36 0 0 0 12 13.885a33.36 33.36 0 0 0 3.397-.166c1.04-.152 1.853-1.03 1.853-2.163v-1.01c0-1.133-.813-2.01-1.853-2.163A33.36 33.36 0 0 0 12 8.217Z" />
              </svg>
              Chat
            </.link>
          </nav>
          <.separator class="bg-gray-800" />
          <div class="px-3 py-3 space-y-1">
            <p class="px-2 mb-2 text-[11px] font-medium text-gray-500 uppercase tracking-wider">Account</p>
            <.link navigate={~p"/users/profile"} class="flex items-center gap-3 px-2 py-2 text-sm text-gray-400 rounded-md hover:bg-gray-800/50 hover:text-gray-200 transition-colors">
              <.icon name="hero-user-circle" class="w-4 h-4" />
              Profile
            </.link>
            <.link navigate={~p"/users/settings"} class="flex items-center gap-3 px-2 py-2 text-sm text-gray-400 rounded-md hover:bg-gray-800/50 hover:text-gray-200 transition-colors">
              <.icon name="hero-cog-6-tooth" class="w-4 h-4" />
              Settings
            </.link>
            <.link href={~p"/users/log-out"} method="delete" class="flex items-center gap-3 px-2 py-2 text-sm text-red-400 rounded-md hover:bg-red-500/10 hover:text-red-300 transition-colors">
              <.icon name="hero-arrow-right-on-rectangle" class="w-4 h-4" />
              Sign out
            </.link>
          </div>
        </div>
      </.sheet_content>
    </.sheet>
    <img src={~p"/images/logo-icon.svg"} alt="AgentEx" class="h-7 w-7" />
    <span class="text-base font-semibold text-white">AgentEx</span>
  </div>

  <!-- Sidebar -->
  <aside class="hidden lg:flex lg:w-48 flex-col flex-shrink-0 bg-gray-900 border-r border-gray-800">
    <!-- Logo -->
    <div class="flex items-center gap-2 h-14 px-3 lg:px-4 border-b border-gray-800">
      <img src={~p"/images/logo-icon.svg"} alt="AgentEx" class="h-7 w-7 shrink-0 mx-auto lg:mx-0" />
      <span class="hidden lg:inline font-semibold text-white text-sm truncate">AgentEx</span>
    </div>

    <!-- Navigation -->
    <nav class="flex-1 px-3 py-3 space-y-1">
      <p class="px-2 mb-2 text-[11px] font-medium text-gray-500 uppercase tracking-wider">Platform</p>
      <.link navigate={~p"/chat"} class={[
        "flex items-center gap-3 px-2 py-2 rounded-md transition-colors",
        nav_active?(@socket, AgentExWeb.ChatLive) && "bg-gray-800 text-white font-medium" || "text-gray-400 hover:bg-gray-800/50 hover:text-gray-200"
      ]}>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 shrink-0">
          <path d="M3.505 2.365A41.369 41.369 0 0 1 9 2c1.863 0 3.697.124 5.495.365 1.247.167 2.18 1.108 2.435 2.268a4.45 4.45 0 0 0-.577-.069 43.36 43.36 0 0 0-4.353 0C9.168 4.749 7 6.733 7 9.035c0 1.358.635 2.565 1.625 3.346-.463.305-.96.559-1.484.756-1.077.405-1.916-.265-1.916-1.378V10.5c0-.235.007-.467.022-.696A4.998 4.998 0 0 1 2 5.869V5.75c0-1.505.923-2.97 2.17-3.29a.228.228 0 0 0-.165-.035ZM12 8.217a33.36 33.36 0 0 0-3.397.166c-1.04.152-1.853 1.03-1.853 2.163v1.01c0 1.133.813 2.01 1.853 2.163A33.36 33.36 0 0 0 12 13.885a33.36 33.36 0 0 0 3.397-.166c1.04-.152 1.853-1.03 1.853-2.163v-1.01c0-1.133-.813-2.01-1.853-2.163A33.36 33.36 0 0 0 12 8.217Z" />
        </svg>
        <span class="text-sm">Chat</span>
      </.link>
    </nav>

    <!-- Footer -->
    <div class="flex items-center px-3 h-[60px] border-t border-gray-800">
      <.dropdown_menu id="user-menu" use-portal>
        <.dropdown_menu_trigger>
          <button type="button" class="flex items-center gap-2 w-full px-2 py-1.5 rounded-md text-gray-400 hover:bg-gray-800/50 hover:text-white transition-colors md:justify-center lg:justify-start">
            <div class="flex h-7 w-7 items-center justify-center rounded-full bg-indigo-600 text-[10px] font-bold text-white shrink-0">
              <%= if assigns[:current_scope] && @current_scope.user do %>
                <%= initials(@current_scope.user.username || @current_scope.user.email) %>
              <% else %>
                ?
              <% end %>
            </div>
            <span class="hidden lg:block text-sm text-white truncate flex-1 text-left">
              <%= if assigns[:current_scope] && @current_scope.user do %>
                <%= @current_scope.user.username || @current_scope.user.email %>
              <% end %>
            </span>
            <.icon name="hero-ellipsis-vertical" class="w-4 h-4 hidden lg:block shrink-0 text-gray-500" />
          </button>
        </.dropdown_menu_trigger>
        <.dropdown_menu_content side="top" class="w-48 mb-1">
          <.dropdown_menu_label>My Account</.dropdown_menu_label>
          <.dropdown_menu_separator />
          <.dropdown_menu_item>
            <.link navigate={~p"/users/profile"} class="flex items-center gap-2 w-full">
              <.icon name="hero-user-circle" class="w-4 h-4" />
              Profile
            </.link>
          </.dropdown_menu_item>
          <.dropdown_menu_item>
            <.link navigate={~p"/users/settings"} class="flex items-center gap-2 w-full">
              <.icon name="hero-cog-6-tooth" class="w-4 h-4" />
              Settings
            </.link>
          </.dropdown_menu_item>
          <.dropdown_menu_separator />
          <.dropdown_menu_item variant="destructive">
            <.link href={~p"/users/log-out"} method="delete" class="flex items-center gap-2 w-full">
              <.icon name="hero-arrow-right-on-rectangle" class="w-4 h-4" />
              Sign out
            </.link>
          </.dropdown_menu_item>
        </.dropdown_menu_content>
      </.dropdown_menu>
    </div>
  </aside>

  <!-- Main content -->
  <main class="flex-1 flex flex-col overflow-hidden pt-14 lg:pt-0">
    <.flash_group flash={@flash} />
    <%= if assigns[:inner_block] do %>
      <%= render_slot(@inner_block) %>
    <% else %>
      {@inner_content}
    <% end %>
  </main>
</div>
