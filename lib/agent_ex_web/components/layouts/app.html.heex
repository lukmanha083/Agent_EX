<div class="flex h-screen bg-gray-950">
  <!-- Sidebar -->
  <nav class="w-56 bg-gray-900 border-r border-gray-800 flex flex-col">
    <div class="p-4 border-b border-gray-800">
      <h1 class="text-lg font-bold text-white tracking-tight">AgentEx</h1>
      <p class="text-xs text-gray-500 mt-0.5">AI Agent Framework</p>
    </div>

    <div class="flex-1 p-3 space-y-1">
      <a href="/" class="flex items-center gap-2 px-3 py-2 text-sm text-gray-300 rounded-md hover:bg-gray-800 hover:text-white transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
        </svg>
        Chat
      </a>
    </div>

    <div class="p-3 border-t border-gray-800 space-y-1">
      <.link navigate={~p"/users/settings"} class="flex items-center gap-2 px-3 py-2 text-sm text-gray-400 rounded-md hover:bg-gray-800 hover:text-white transition-colors">
        <.icon name="hero-user-circle" class="w-4 h-4" />
        Profile
      </.link>
      <p class="text-xs text-gray-600 px-3 mt-2">v<%= Application.spec(:agent_ex, :vsn) |> to_string() %></p>
    </div>
  </nav>

  <!-- Main content -->
  <main class="flex-1 flex flex-col overflow-hidden">
    <.flash_group flash={@flash} />
    <%= if assigns[:inner_block] do %>
      <%= render_slot(@inner_block) %>
    <% else %>
      {@inner_content}
    <% end %>
  </main>
</div>
