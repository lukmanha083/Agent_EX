<div class="flex h-full">
  <!-- Conversation sidebar (toggleable, hidden by default) -->
  <div class={[
    "flex-shrink-0 transition-all duration-200 ease-in-out overflow-hidden",
    @show_history && "w-52 border-r border-gray-800" || "w-0"
  ]}>
    <div class="w-52 h-full">
      <.conversation_sidebar
        conversations={@conversations}
        current_id={@conversation && @conversation.id}
        timezone={@timezone}
      />
    </div>
  </div>

  <!-- Chat area -->
  <div class="flex flex-col flex-1 min-w-0">
    <!-- Header -->
    <header class="flex items-center gap-2 md:gap-3 px-3 md:px-4 h-14 border-b border-gray-800 bg-gray-900/50">
      <!-- History toggle button -->
      <button
        type="button"
        phx-click="toggle_history"
        class={[
          "flex items-center justify-center w-8 h-8 rounded-md transition-colors",
          @show_history && "bg-gray-800 text-white" || "text-gray-400 hover:bg-gray-800 hover:text-white"
        ]}
        aria-label="Toggle conversation history"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
          <path fill-rule="evenodd" d="M2 4.75A.75.75 0 0 1 2.75 4h14.5a.75.75 0 0 1 0 1.5H2.75A.75.75 0 0 1 2 4.75ZM2 10a.75.75 0 0 1 .75-.75h14.5a.75.75 0 0 1 0 1.5H2.75A.75.75 0 0 1 2 10Zm0 5.25a.75.75 0 0 1 .75-.75h14.5a.75.75 0 0 1 0 1.5H2.75a.75.75 0 0 1-.75-.75Z" clip-rule="evenodd" />
        </svg>
      </button>
      <.badge :if={assigns[:current_project]} variant="outline" class="text-indigo-400 border-indigo-500/30">{@current_project.name}</.badge>
      <.badge variant="secondary">{@model}</.badge>
      <div class="ml-auto flex items-center gap-1">
        <button type="button" phx-click="clear" class="flex items-center gap-1 px-2 py-1 rounded-md text-sm text-gray-400 hover:bg-gray-800 hover:text-white transition-colors" aria-label="Clear conversation">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
            <path fill-rule="evenodd" d="M8.75 1A2.75 2.75 0 0 0 6 3.75v.443c-.795.077-1.584.176-2.365.298a.75.75 0 1 0 .23 1.482l.149-.022.841 10.518A2.75 2.75 0 0 0 7.596 19h4.807a2.75 2.75 0 0 0 2.742-2.53l.841-10.519.149.023a.75.75 0 0 0 .23-1.482A41.03 41.03 0 0 0 14 4.193V3.75A2.75 2.75 0 0 0 11.25 1h-2.5ZM10 4c.84 0 1.673.025 2.5.075V3.75c0-.69-.56-1.25-1.25-1.25h-2.5c-.69 0-1.25.56-1.25 1.25v.325C8.327 4.025 9.16 4 10 4ZM8.58 7.72a.75.75 0 0 0-1.5.06l.3 7.5a.75.75 0 1 0 1.5-.06l-.3-7.5Zm4.34.06a.75.75 0 1 0-1.5-.06l-.3 7.5a.75.75 0 1 0 1.5.06l.3-7.5Z" clip-rule="evenodd" />
          </svg>
          <span class="hidden md:inline">Clear</span>
        </button>
      </div>
    </header>

    <!-- Messages area -->
    <div id="messages" data-testid="messages" role="log" aria-live="polite" class="flex-1 overflow-y-auto py-4 space-y-1" phx-hook="ScrollBottom">
      <div :if={@messages == []} class="flex items-center justify-center h-full">
        <div class="text-center space-y-3">
          <.icon name="hero-chat-bubble-left-right" class="w-12 h-12 text-gray-700 mx-auto" />
          <p class="text-gray-500 text-sm" data-testid="empty-state">Start a conversation</p>
          <.badge variant="secondary">{@model}</.badge>
        </div>
      </div>

      <div :for={msg <- @messages}>
        <.message_bubble role={msg.role} content={msg.content} model={@model} user_initials={@user_initials} />
      </div>

      <!-- Agent tree (shown during orchestration runs) -->
      <.agent_tree
        :if={@agent_tree != %{}}
        tree={@agent_tree}
        budget={@agent_tree_budget}
        task_stats={@agent_tree_stats}
        logs={@agent_logs}
        expanded={@expanded_agent}
      />

      <!-- Orchestration warning banner -->
      <.orchestration_banner active={@agent_tree != %{}} />

      <!-- Tool call cards (non-orchestration runs) -->
      <div :if={@agent_tree == %{}} :for={event <- @events}>
        <.tool_card
          :if={event.type == :tool_call}
          name={event.data.tool_name}
          status={tool_status(event.data.call_id, @events)}
        />
      </div>

      <!-- Pipeline stages (non-orchestration) -->
      <.pipeline_stages :if={@agent_tree == %{}} stages={@stages} />

      <!-- Todo checklist (live updates from specialist agent) -->
      <div :if={@todo_items != ""} class="px-4 py-2">
        <div class="rounded-lg border border-emerald-500/20 bg-emerald-500/5 p-3">
          <div class="flex items-center gap-2 mb-2">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 text-emerald-400">
              <path fill-rule="evenodd" d="M6 4.75A.75.75 0 0 1 6.75 4h10.5a.75.75 0 0 1 0 1.5H6.75A.75.75 0 0 1 6 4.75ZM6 10a.75.75 0 0 1 .75-.75h10.5a.75.75 0 0 1 0 1.5H6.75A.75.75 0 0 1 6 10Zm0 5.25a.75.75 0 0 1 .75-.75h10.5a.75.75 0 0 1 0 1.5H6.75a.75.75 0 0 1-.75-.75ZM1.99 4.75a1 1 0 0 1 1-1h.01a1 1 0 0 1 0 2h-.01a1 1 0 0 1-1-1Zm1 5.25a1 1 0 0 1 1-1h.01a1 1 0 0 1 0 2h-.01a1 1 0 0 1-1-1Zm0 5.25a1 1 0 0 1 1-1h.01a1 1 0 0 1 0 2h-.01a1 1 0 0 1-1-1Z" clip-rule="evenodd" />
            </svg>
            <span class="text-xs font-medium text-emerald-400">Specialist Checklist</span>
          </div>
          <div class="space-y-0.5">
            <p :for={line <- String.split(@todo_items, "\n", trim: true)} class={[
              "text-xs font-mono",
              cond do
                String.contains?(line, "[x]") -> "text-emerald-400"
                String.contains?(line, "[~]") -> "text-amber-400"
                true -> "text-gray-400"
              end
            ]}><%= line %></p>
          </div>
        </div>
      </div>

      <!-- Thinking indicator -->
      <.thinking_indicator active={@thinking} />
    </div>

    <!-- Input area -->
    <div class="border-t border-gray-800 bg-gray-900/50 p-3">
      <!-- Agent question prompt -->
      <div :if={@pending_question} class="mb-3 rounded-lg border border-amber-500/30 bg-amber-500/5 p-3">
        <div class="flex items-start gap-2 mb-2">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 text-amber-400 flex-shrink-0 mt-0.5">
            <path fill-rule="evenodd" d="M18 10a8 8 0 1 1-16 0 8 8 0 0 1 16 0Zm-7-4a1 1 0 1 1-2 0 1 1 0 0 1 2 0ZM9 9a.75.75 0 0 0 0 1.5h.253a.25.25 0 0 1 .244.304l-.459 2.066A1.75 1.75 0 0 0 10.747 15H11a.75.75 0 0 0 0-1.5h-.253a.25.25 0 0 1-.244-.304l.459-2.066A1.75 1.75 0 0 0 9.253 9H9Z" clip-rule="evenodd" />
          </svg>
          <p class="text-sm text-amber-200"><%= @pending_question %></p>
        </div>
        <form phx-submit="submit_answer" class="flex gap-2">
          <label for="answer_input" class="sr-only">Your answer</label>
          <input
            id="answer_input"
            type="text"
            name="answer"
            placeholder="Type your answer..."
            autocomplete="off"
            autofocus
            class="flex-1 bg-gray-800 border border-amber-500/30 text-white rounded-lg px-3 md:px-4 py-2.5 text-sm placeholder-gray-500 focus:border-amber-500 focus:ring-1 focus:ring-amber-500 min-h-[44px]"
          />
          <.button type="submit" class="min-h-[44px] bg-amber-600 hover:bg-amber-500" aria-label="Submit answer">
            Reply
          </.button>
          <.button variant="destructive" type="button" phx-click="cancel" class="min-h-[44px]" aria-label="Cancel">
            Cancel
          </.button>
        </form>
      </div>
      <!-- Normal message input -->
      <form :if={!@pending_question} phx-submit="send" class="flex gap-2">
        <label for="message_input" class="sr-only">Message</label>
        <input
          id="message_input"
          type="text"
          name="message"
          value={@input}
          placeholder="Type a message..."
          autocomplete="off"
          disabled={@thinking}
          class={[
            "flex-1 bg-gray-800 border border-gray-700 text-white rounded-lg px-3 md:px-4 py-2.5 text-sm",
            "placeholder-gray-500 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500",
            "disabled:opacity-50 disabled:cursor-not-allowed min-h-[44px]"
          ]}
        />
        <.button :if={!@thinking} type="submit" class="min-h-[44px]" aria-label="Send message">
          Send
        </.button>
        <.button :if={@thinking} variant="destructive" type="button" phx-click="cancel" class="min-h-[44px]" aria-label="Cancel">
          Cancel
        </.button>
      </form>
    </div>
  </div>
</div>
