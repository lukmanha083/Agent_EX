<div class="flex h-full">
  <!-- Conversation sidebar (hidden on mobile, shown on lg+) -->
  <div class="hidden lg:flex lg:w-52 flex-shrink-0">
    <.conversation_sidebar
      conversations={@conversations}
      current_id={@conversation && @conversation.id}
    />
  </div>

  <!-- Chat area -->
  <div class="flex flex-col flex-1 min-w-0">
    <!-- Header -->
    <header class="flex items-center gap-2 md:gap-3 px-3 md:px-4 py-2.5 border-b border-gray-800 bg-gray-900/50">
      <.badge variant="secondary">{@model}</.badge>
      <span :if={@conversation} class="text-xs text-gray-500 truncate hidden md:inline">
        {@conversation.title}
      </span>
      <div class="ml-auto flex items-center gap-1">
        <.button variant="ghost" size="sm" phx-click="new_chat" class="md:hidden" aria-label="New chat">
          <.icon name="hero-plus" class="w-3.5 h-3.5" />
        </.button>
        <.button variant="ghost" size="sm" phx-click="clear" aria-label="Clear conversation">
          <.icon name="hero-trash" class="w-3.5 h-3.5 md:mr-1" />
          <span class="sr-only md:not-sr-only md:inline">Clear</span>
        </.button>
      </div>
    </header>

    <!-- Messages area -->
    <div id="messages" class="flex-1 overflow-y-auto py-4 space-y-1" phx-hook="ScrollBottom">
      <div :if={@messages == []} class="flex items-center justify-center h-full">
        <div class="text-center space-y-3">
          <.icon name="hero-chat-bubble-left-right" class="w-12 h-12 text-gray-700 mx-auto" />
          <p class="text-gray-500 text-sm">Start a conversation</p>
          <.badge variant="secondary">{@model}</.badge>
        </div>
      </div>

      <div :for={msg <- @messages}>
        <.message_bubble role={msg.role} content={msg.content} model={@model} user_initials={@user_initials} />
      </div>

      <!-- Tool call cards -->
      <div :for={event <- @events}>
        <.tool_card
          :if={event.type == :tool_call}
          name={event.data.tool_name}
          status={tool_status(event.data.call_id, @events)}
        />
      </div>

      <!-- Pipeline stages -->
      <.pipeline_stages stages={@stages} />

      <!-- Thinking indicator -->
      <.thinking_indicator active={@thinking} />
    </div>

    <!-- Input area -->
    <div class="border-t border-gray-800 bg-gray-900/50 p-3 md:p-4">
      <form phx-submit="send" class="flex gap-2">
        <label for="message_input" class="sr-only">Message</label>
        <input
          id="message_input"
          type="text"
          name="message"
          value={@input}
          placeholder="Type a message..."
          autocomplete="off"
          disabled={@thinking}
          class={[
            "flex-1 bg-gray-800 border border-gray-700 text-white rounded-lg px-3 md:px-4 py-2.5 text-sm",
            "placeholder-gray-500 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500",
            "disabled:opacity-50 disabled:cursor-not-allowed min-h-[44px]"
          ]}
        />
        <.button :if={!@thinking} type="submit" class="min-h-[44px]" aria-label="Send message">
          <.icon name="hero-paper-airplane" class="w-4 h-4 md:hidden" />
          <span class="sr-only md:not-sr-only md:inline">Send</span>
        </.button>
        <.button :if={@thinking} variant="destructive" type="button" phx-click="cancel" class="min-h-[44px]" aria-label="Cancel">
          <.icon name="hero-stop" class="w-4 h-4 md:hidden" />
          <span class="sr-only md:not-sr-only md:inline">Cancel</span>
        </.button>
      </form>
    </div>
  </div>
</div>
