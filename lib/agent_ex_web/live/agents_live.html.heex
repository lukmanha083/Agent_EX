<div class="flex flex-col h-full">
  <!-- Header -->
  <header class="flex items-center justify-between px-4 md:px-6 h-14 border-b border-gray-800 bg-gray-900/50 shrink-0">
    <div>
      <h1 class="text-base font-semibold text-white">Agents</h1>
      <p class="text-xs text-gray-500">
        <span :if={assigns[:current_project]} class="text-indigo-400">{@current_project.name}</span>
        <span :if={assigns[:current_project]}> — </span>Create and manage AI agents
      </p>
    </div>
  </header>

  <!-- Content -->
  <div class="flex-1 overflow-y-auto p-4 md:p-6">
    <%= if @project.is_default do %>
      <!-- Gate: requires a named project -->
      <div class="flex flex-col items-center justify-center py-16 text-center">
        <div class="flex h-12 w-12 items-center justify-center rounded-full bg-gray-800 mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-6 h-6 text-gray-400">
            <path d="M3.75 3A1.75 1.75 0 0 0 2 4.75v3.26a3.235 3.235 0 0 1 1.75-.51h12.5c.644 0 1.245.188 1.75.51V6.75A1.75 1.75 0 0 0 16.25 5h-4.836a.25.25 0 0 1-.177-.073L9.823 3.513A1.75 1.75 0 0 0 8.586 3H3.75ZM3.75 9A1.75 1.75 0 0 0 2 10.75v4.5c0 .966.784 1.75 1.75 1.75h12.5A1.75 1.75 0 0 0 18 15.25v-4.5A1.75 1.75 0 0 0 16.25 9H3.75Z" />
          </svg>
        </div>
        <h2 class="text-lg font-medium text-white mb-1">Create a project first</h2>
        <p class="text-sm text-gray-400 mb-6 max-w-sm">
          Agents belong to projects. Create a project with a name and sandbox path to get started.
        </p>
        <.link
          navigate={~p"/projects"}
          class="inline-flex items-center gap-2 rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-500 transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
            <path d="M10.75 4.75a.75.75 0 0 0-1.5 0v4.5h-4.5a.75.75 0 0 0 0 1.5h4.5v4.5a.75.75 0 0 0 1.5 0v-4.5h4.5a.75.75 0 0 0 0-1.5h-4.5v-4.5Z" />
          </svg>
          Create a project
        </.link>
      </div>
    <% else %>
      <%= if @agents == [] and not @show_editor do %>
        <div class="flex flex-col items-center justify-center py-16 text-center">
          <div class="flex h-12 w-12 items-center justify-center rounded-full bg-gray-800 mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-6 h-6 text-gray-400">
              <path d="M10 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM3.465 14.493a1.23 1.23 0 0 0 .41 1.412A9.957 9.957 0 0 0 10 18c2.31 0 4.438-.784 6.131-2.1.43-.333.604-.903.408-1.41a7.002 7.002 0 0 0-13.074.003Z" />
            </svg>
          </div>
          <h2 class="text-lg font-medium text-white mb-1">No agents yet</h2>
          <p class="text-sm text-gray-400 mb-6 max-w-sm">
            Agents are AI assistants with specific roles, tools, and memory configurations.
          </p>
          <button
            type="button"
            phx-click="new_agent"
            class="inline-flex items-center gap-2 rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-500 transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
              <path d="M10.75 4.75a.75.75 0 0 0-1.5 0v4.5h-4.5a.75.75 0 0 0 0 1.5h4.5v4.5a.75.75 0 0 0 1.5 0v-4.5h4.5a.75.75 0 0 0 0-1.5h-4.5v-4.5Z" />
            </svg>
            Create your first agent
          </button>
        </div>
      <% else %>
        <.agent_grid agents={@agents} project_root_path={@project.root_path} />
      <% end %>
    <% end %>
  </div>

  <!-- Editor dialog (only when not on default project) -->
  <.agent_editor_dialog
    :if={not @project.is_default}
    agent={@editing}
    form={@form}
    show={@show_editor}
    provider_options={@provider_options}
    model_options={@model_options}
    intervention_pipeline={@intervention_pipeline}
    sandbox={@sandbox}
    project_root_path={@project.root_path}
  />
</div>
