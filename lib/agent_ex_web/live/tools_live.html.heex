<div class="flex flex-col h-full">
  <!-- Header -->
  <header class="flex items-center justify-between px-4 md:px-6 h-14 border-b border-gray-800 bg-gray-900/50 shrink-0">
    <div>
      <h1 class="text-base font-semibold text-white">Tools</h1>
      <p class="text-xs text-gray-500">
        <span :if={assigns[:current_project]} class="text-indigo-400">{@current_project.name}</span>
        <span :if={assigns[:current_project]}> — </span>Manage tool sources and connections
      </p>
    </div>
  </header>

  <!-- Content -->
  <div class="flex-1 overflow-y-auto p-4 md:p-6">
    <.tool_tabs
      active_tab={@active_tab}
      builtin_plugins={@builtin_plugins}
      available_plugins={@available_plugins}
      mcp_servers={@mcp_servers}
      attached_sources={@attached_sources}
      http_tools={@http_tools}
      builtin_mcp_servers={@builtin_mcp_servers}
      show_builtin_mcp_editor={@show_builtin_mcp_editor}
      builtin_mcp_editing={@builtin_mcp_editing}
      builtin_mcp_form={@builtin_mcp_form}
    />
  </div>

  <!-- Dialogs -->
  <.mcp_connect_dialog show={@show_mcp_form} form={@mcp_form} />
  <.http_tool_editor_dialog
    show={@show_http_editor}
    form={@http_form}
    editing={@editing_http_tool}
    test_result={@http_test_result}
    test_loading={@http_test_loading}
  />
</div>
