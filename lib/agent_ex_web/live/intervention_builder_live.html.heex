<div class="flex flex-col h-full">
  <!-- Header -->
  <header class="flex items-center justify-between px-4 md:px-6 h-14 border-b border-gray-800 bg-gray-900/50 shrink-0">
    <div>
      <h1 class="text-base font-semibold text-white">Interventions</h1>
      <p class="text-xs text-gray-500">Build tool call intervention pipelines</p>
    </div>
  </header>

  <!-- Content -->
  <div class="flex-1 overflow-y-auto p-4 md:p-6 max-w-2xl">
    <.intervention_pipeline pipeline={@pipeline} available={@available} />
  </div>
</div>
